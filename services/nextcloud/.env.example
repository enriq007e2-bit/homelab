# Nextcloud stack — variables de entorno
# Copia este archivo a .env y rellena los valores
# Genera contraseñas seguras con: openssl rand -hex 16  (o -base64 12 | tr -d '/+=')

# Base de datos
DB_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD
DB_PASSWORD=CHANGE_ME_DB_PASSWORD

# Admin de Nextcloud (se crea en el primer boot)
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD

# Collabora
COLLABORA_PASSWORD=CHANGE_ME_COLLABORA_PASSWORD