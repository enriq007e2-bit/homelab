# Immich — variables de entorno para aranet (SIN ML)
# Copia a .env y rellena

# Dónde guardar las fotos (disco de datos OMV — mucho espacio)
UPLOAD_LOCATION=/srv/dev-disk-by-uuid-3cbf356b-5d12-46da-be09-b46af845c46d/immich/library

# Dónde guardar la base de datos (SSD del sistema — mejor rendimiento)
DB_DATA_LOCATION=/opt/immich/postgres

# Zona horaria
TZ=America/Mexico_City

# Versión de Immich (pinea a release estable)
IMMICH_VERSION=v3

# PostgreSQL
DB_PASSWORD=CHANGE_ME_DB_PASSWORD
DB_USERNAME=postgres
DB_DATABASE_NAME=immich

# ML DESHABILITADO (ahorra RAM)
IMMICH_MACHINE_LEARNING_ENABLED=false